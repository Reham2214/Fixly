@{

}
@model List<Fixly.Models.ServiceRequest>

<style>
    .table thead th {
        color: var(--bs-secondary-color);
    }
</style>
<div class="container mt-5">

    <h2 class="fw-bold">
        Incoming Requests
    </h2>

    <p class="text-secondary">
        Jobs customers have sent your way.
    </p>

    <div class="card shadow border-0 rounded-2">
        <div class="card-body rounded-4">

        
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Service</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Problem</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var req in ViewBag.ServiceRequest)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @req.Customer
                            </td>

                            <td>
                                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                                    @req.Service
                                </span>
                            </td>

                            <td>
                                @req.RequestedDate
                            </td>

                            <td>
                                @req.RequestedTime
                            </td>

                            <td>
                                @req.ProblemDescription
                            </td>

                            <td>
                                <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill">
                                    @req.Status
                                </span>
                            </td>

                            <td>
                                <button class="btn bg-success-subtle btn-sm text-success px-3 rounded-3">
                                    Accept
                                </button>

                                <button class="btn bg-danger-subtle btn-sm text-danger px-3 rounded-3">
                                    Reject
                                </button>
                            </td>
                        </tr>
                    }

