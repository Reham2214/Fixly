                                    @req.Provider
                                </span>
                            </td>

                            <td>
                                @req.RequestedDate.ToString("yyyy-MM-dd")
                            </td>

                            <td>
                                @req.RequestedTime
                            </td>

                            <td>
                                @req.ProblemDescription
                            </td>

                            <td>
                                <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill">
                                    @req.Status
                                </span>
                            </td>

                            <td>
                                <button class="btn btn-success btn-sm">
                                    Accept
                                </button>

                                <button class="btn btn-danger btn-sm">
                                    Reject
                                </button>
                            </td>
                        </tr>
                    } *@
                </tbody>
            </table>

        </div>
    </div>

</div>