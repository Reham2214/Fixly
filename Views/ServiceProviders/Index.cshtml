@model List<Fixly.Models.MyRequestViewModel>


<style>
    .table thead th {
        color: var(--bs-secondary-color);
    }
</style>

<div class="container mt-5">

    <h2 class="fw-bold">
        Incoming Requests
    </h2>

    <p class="text-secondary">
        Jobs customers have sent your way.
    </p>

    <div class="card shadow border-0 rounded-2">
        <div class="card-body rounded-4">

            @if (!Model.Any())
            {
                <p class="text-center text-secondary py-4">
                    No incoming requests found.
                </p>
            }
            else
            {
                <table class="table align-middle mb-0">

                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Service</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Problem</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            var req = item.Request;

                            <tr>

                                <td class="fw-semibold">
                                    @req.Customer.FullName
                                </td>

                                <td>
                                    <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                                        @item.ServiceCategory
                                    </span>
                                </td>

                                <td>
                                    @req.RequestedDate.ToString("yyyy-MM-dd")
                                </td>

                                <td>
                                    @req.RequestedTime
                                </td>

                                <td>
                                    @req.ProblemDescription
                                </td>

                                <td>
                                    @{
                                        var badgeClass = req.Status switch
                                        {
                                            Fixly.Models.RequestStatus.Pending
                                                => "bg-warning-subtle text-warning",

                                            Fixly.Models.RequestStatus.Accepted
                                                => "bg-success-subtle text-success",

                                            Fixly.Models.RequestStatus.Rejected
                                                => "bg-danger-subtle text-danger",

                                            Fixly.Models.RequestStatus.Completed
                                                => "bg-secondary-subtle text-secondary",

                                            _ => "bg-light text-dark"
                                        };
                                    }

                                    <span class="badge @badgeClass px-3 py-2 rounded-pill">
                                        @req.Status
                                    </span>
                                </td>

                                <td>
                                    @if (req.Status == Fixly.Models.RequestStatus.Pending)
                                    {
                                        <button class="btn bg-success-subtle btn-sm text-success px-3 rounded-3">
                                            Accept
                                        </button>

                                        <button class="btn bg-danger-subtle btn-sm text-danger px-3 rounded-3">
                                            Reject
                                        </button>
                                    }
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }

        </div>
    </div>

</div>